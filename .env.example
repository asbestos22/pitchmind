# PitchMind — secrets (DO NOT COMMIT)
# Copy to .env and fill in. Run `npm run provision` to generate the account + delegate key.

# Walrus Memory hosted MAINNET relayer (relayer pays WAL+SUI for storage)
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz
MEMWAL_ACCOUNT_PROVISION_URL=https://memory.walrus.xyz

# Filled by `npm run provision`:
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=

# Dedicated Sui wallet created for Walrus Sessions (mainnet). Address only here; keep the
# private key in your Sui keystore, never in this repo.
SESSION_WALLET_ADDRESS=

# Namespace isolates this agent's memories
MEMWAL_NAMESPACE=pitchmind-wc2026

# LLM for roast generation (OpenAI-compatible). Optional — falls back to template roasts.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Web server
PORT=8787
