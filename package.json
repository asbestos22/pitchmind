{
  "name": "pitchmind",
  "version": "0.1.0",
  "private": true,
  "description": "An AI agent that remembers your FIFA World Cup 2026 predictions on Walrus Memory and roasts your biases with receipts.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "predict": "tsx src/cli.ts predict",
    "result": "tsx src/cli.ts result",
    "roast": "tsx src/cli.ts roast",
    "recap": "tsx src/cli.ts recap",
    "export": "tsx src/cli.ts export",
    "serve": "tsx src/server.ts",
    "provision": "tsx scripts/provision-account.ts",
    "health": "tsx src/cli.ts health"
  },
  "dependencies": {
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/sui": "^1.45.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
